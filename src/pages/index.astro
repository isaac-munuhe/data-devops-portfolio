---
import { getCollection } from 'astro:content';
import Navigation from '../components/Navigation';
import Hero from '../components/Hero';
import About from '../components/About';
import Skills from '../components/Skills';
import Experience from '../components/Experience';
import Blog from '../components/Blog';
import Contact from '../components/Contact';
import '../styles/global.css';

// Fetch the collection
const allPosts = await getCollection('blog');

// Safely map and sort for the production build
const formattedPosts = allPosts
  .sort((a, b) => {
    const dateA = a.data.date instanceof Date ? a.data.date.getTime() : new Date(a.data.date).getTime();
    const dateB = b.data.date instanceof Date ? b.data.date.getTime() : new Date(b.data.date).getTime();
    return dateB - dateA;
  })
  .map(post => {
    // Standardize the ID for the URL
    const rawId = post.id || post.slug || 'entry';
    const cleanId = rawId.replace(/\.mdx?$/, ''); 
    
    // Ensure we have a valid date string for the React component
    const displayDate = post.data.date instanceof Date 
      ? post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
      : new Date(post.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

    return {
      id: cleanId,
      slug: cleanId,
      url: `/blog/${cleanId}`,
      articleUrl: `/blog/${cleanId}`, // Failsafe for the Blog component
      title: post.data.title,
      description: post.data.description,
      date: displayDate,
      readTime: post.data.readTime,
      category: post.data.category,
      tags: post.data.tags || []
    };
  })
  .slice(0, 4);
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Data and DevOps Engineering Portfolio by Wilson W Isaac" />
    <title>Wilson W Isaac | Data & DevOps</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#060b18] text-[#e8edf5] font-sans antialiased selection:bg-[#2979ff] selection:text-white">
    
    <Navigation client:load />

    <main class="min-h-screen">
      <Hero client:only="react" />

      <div class="border-t border-[#1e293b]/50">
        <About client:only="react" />
      </div>

      <div class="border-t border-[#1e293b]/50">
        <Skills client:only="react" />
      </div>

      <div class="border-t border-[#1e293b]/50">
        <Experience client:only="react" />
      </div>

      <div class="border-t border-[#1e293b]/50 bg-[#0a0f1e]/50">
        {/* Pass the formatted posts to the React component */}
        <Blog posts={formattedPosts} client:only="react" />
      </div>

      <div class="border-t border-[#1e293b]/50">
        <Contact client:only="react" />
      </div>
    </main>

  </body>
</html>